# =============================================
# WiseBook Frontend - Configuration
# =============================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Environment
VITE_APP_ENV=development

# Accès restreint — liste blanche d'emails autorisés (séparés par virgules)
# Laisser vide = tout le monde peut se connecter
VITE_ALLOWED_EMAILS=
VITE_APP_VERSION=3.0.0
VITE_APP_NAME="WiseBook ERP"

# Company Configuration
VITE_DEFAULT_CURRENCY=XAF
VITE_DEFAULT_LANGUAGE=fr
VITE_DEFAULT_COUNTRY=CM

# Features Flags
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_MULTI_LANGUAGE=true
VITE_ENABLE_PRINTING=true
VITE_ENABLE_EXPORT=true

# Data Mode (local = Dexie.js, saas = Supabase, hybrid = local-first + sync)
VITE_DATA_MODE=local

# PROPH3T — LLM Provider
# Provider principal : Ollama (local, gratuit, aucune clé requise)
# Installation : https://ollama.ai → ollama pull mistral
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=mistral

# PROPH3T — Providers optionnels (laisser vide si non utilisé)
# Set to 'true' to enable Anthropic via server-side proxy (API key configured in Supabase Secrets)
VITE_ANTHROPIC_ENABLED=false
# Atlas Studio main site URL (for "Atlas Studio" brand redirects)
VITE_ATLAS_STUDIO_URL=https://www.atlas-studio.org

# External Services
VITE_SENTRY_DSN=


# File Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,csv,xlsx

# UI Configuration
VITE_ITEMS_PER_PAGE=20
VITE_MAX_ITEMS_PER_PAGE=100
VITE_SIDEBAR_COLLAPSED=false

# Printing
VITE_DEFAULT_PRINT_FORMAT=A4
VITE_DEFAULT_PRINT_ORIENTATION=landscape
