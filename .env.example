# =============================================
# WiseBook Frontend - Configuration
# =============================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Environment
VITE_APP_ENV=development

# Accès restreint — liste blanche d'emails autorisés (séparés par virgules)
# Laisser vide = tout le monde peut se connecter
VITE_ALLOWED_EMAILS=
VITE_APP_VERSION=3.0.0
VITE_APP_NAME="WiseBook ERP"

# Company Configuration
VITE_DEFAULT_CURRENCY=XAF
VITE_DEFAULT_LANGUAGE=fr
VITE_DEFAULT_COUNTRY=CM

# Features Flags
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_MULTI_LANGUAGE=true
VITE_ENABLE_PRINTING=true
VITE_ENABLE_EXPORT=true

# Data Mode (local = Dexie.js, saas = Supabase, hybrid = local-first + sync)
VITE_DATA_MODE=local

# PROPH3T — Core IA (bascule automatique selon l'environnement)
#
# CHEMIN 1 — Orchestrateur serveur déployé `proph3t-ask` (Groq Llama 3.3 + RAG
#   OHADA, conversations persistées). C'est le core IA de prod (Atlas Studio).
#   Activé par DÉFAUT en SaaS (Supabase configuré + pas d'Ollama local).
#  - VITE_PROPH3T_REMOTE non défini -> auto (recommandé)
#  - 'false' -> désactive le chemin serveur (utilise le chemin client ci-dessous)
#  - 'true'  -> force le chemin serveur
# VITE_PROPH3T_REMOTE=
#
# CHEMIN 2 — Provider client-side (fallback / dev), sélection par
# LLMProviderFactory.createFromEnv :
#  1. Si VITE_OLLAMA_BASE_URL est défini  -> Ollama local (dev, gratuit).
#  2. Sinon, si Supabase est configuré    -> Anthropic Claude via l'edge
#     function `ai-proxy` (clé API côté serveur). ACTIVÉ PAR DÉFAUT en SaaS.
#  3. Sinon                                -> mode hors-ligne (pattern-matching).
#
# Dev local avec Ollama (https://ollama.ai → ollama pull mistral) :
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=mistral

# Anthropic (cloud) — activé AUTOMATIQUEMENT dès que Supabase est configuré.
#  - laisser vide  -> auto (recommandé)
#  - 'false'       -> désactive même en SaaS (force le hors-ligne)
#  - 'true'        -> force l'activation même sans Supabase
# VITE_ANTHROPIC_ENABLED=
# Modèle Claude utilisé par ai-proxy (optionnel) :
# VITE_ANTHROPIC_MODEL=claude-sonnet-4-20250514
#
# PRÉREQUIS DÉPLOIEMENT (côté serveur, à faire une fois) :
#  - déployer l'edge function : supabase functions deploy ai-proxy
#  - définir le secret        : supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# ── Fédération « Proph3t core » (Atlas Studio) — CHEMIN 0, optionnel ──────────
# Branche WiseBook sur le CORE IA MUTUALISÉ d'Atlas Studio (mémoire inter-apps,
# RAG SYSCOHADA/OHADA/CGI, outils centraux, audit chaîné). Ces variables
# pointent sur le projet CORE (PAS le Supabase de cette app, ci-dessus).
# Quand elles sont définies, src/lib/proph3t.ts -> askProph3t() délègue le tour
# au core via /functions/v1/proph3t-ask, avec gouvernance par sensibilité
# (confidential -> Ollama/Claude uniquement, jamais de provider à rétention).
# Laisser VIDE = chemin désactivé (les chemins locaux/Excel restent inchangés).
#
# ⚠️ NE JAMAIS committer la vraie anon key : la renseigner dans .env.local.
VITE_ATLAS_SUPABASE_URL=https://vgtmljfayiysuvrcmunt.supabase.co
VITE_ATLAS_SUPABASE_ANON_KEY=

# Atlas Studio main site URL (for "Atlas Studio" brand redirects)
VITE_ATLAS_STUDIO_URL=https://www.atlas-studio.org

# External Services
VITE_SENTRY_DSN=


# File Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,csv,xlsx

# UI Configuration
VITE_ITEMS_PER_PAGE=20
VITE_MAX_ITEMS_PER_PAGE=100
VITE_SIDEBAR_COLLAPSED=false

# Printing
VITE_DEFAULT_PRINT_FORMAT=A4
VITE_DEFAULT_PRINT_ORIENTATION=landscape
