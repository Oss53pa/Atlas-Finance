# Variables d'environnement pour les Supabase Edge Functions
# Copier ce fichier en .env et remplir les valeurs
# NE PAS COMMITER le fichier .env (ajouté au .gitignore)

# URL du projet Supabase
SUPABASE_URL=https://your-project.supabase.co

# Clé service_role (accès admin, bypass RLS) - NE JAMAIS EXPOSER CÔTÉ FRONTEND
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Clé anon (optionnel, utilisé pour le client authentifié utilisateur)
SUPABASE_ANON_KEY=eyJ...

# Anthropic API key (server-side secret for ai-proxy Edge Function)
ANTHROPIC_API_KEY=sk-ant-...

# CORS — override default allowed origin (e.g. for staging)
# ALLOWED_ORIGIN=https://staging.atlas-finance.com
